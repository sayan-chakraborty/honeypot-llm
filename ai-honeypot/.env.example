# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-openai-key>

# Content Safety
CONTENT_SAFETY_ENDPOINT=https://<your-content-safety>.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=<your-content-safety-key>

# Azure Table Storage
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net

# Azure App Configuration
APP_CONFIG_CONNECTION_STRING=Endpoint=https://<your-app-config>.azconfig.io;Id=<id>;Secret=<secret>

# Azure Function App
FUNCTION_APP_URL=https://<your-function-app>.azurewebsites.net
